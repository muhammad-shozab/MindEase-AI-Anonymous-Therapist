# MindEase Environment Variables

# ===========================================
# PRIMARY (Recommended): OpenAI API key for best chatbot quality
# ===========================================
# Get API key from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_key_here

# Optional model override (default in app: gpt-5.1)
# VITE_OPENAI_MODEL=gpt-5.1

# FALLBACK: Gemini API key
# ===========================================
# Used automatically if OpenAI key is missing or request fails.
VITE_GEMINI_KEY=your_gemini_key_here

# ===========================================
# OPTIONAL: Google OAuth Client ID (Drive backup)
# ===========================================
# Setup: enable "Google Drive API" in Cloud Console → APIs & Services → Library
# OAuth client type: Web application
# Authorized JavaScript origins: http://localhost:5173 (plus your deploy URL)
# If OAuth app is "Testing", add your Gmail under Test users on the consent screen
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
# Gmail for the Drive subfolder (MindEase_Sessions/your@gmail.com) — use the account you sign in with
VITE_GOOGLE_DRIVE_FOLDER_EMAIL=your@gmail.com

# ===========================================
# NOTES
# ===========================================
# - Chat works anonymously (no account required)
# - Never commit .env to Git (it is ignored)
# - Restart dev server after env changes

# Optional: EmailJS for direct send (without opening mail app)
# VITE_EMAILJS_SERVICE_ID=service_xxx
# VITE_EMAILJS_TEMPLATE_ID=template_xxx
# VITE_EMAILJS_PUBLIC_KEY=public_xxx

# Optional: EmailJS Private Key (for stricter REST auth)
# VITE_EMAILJS_PRIVATE_KEY=private_xxx
