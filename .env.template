# 🧠 MindEase - Environment Variables
# Copy this file to .env and add your actual API key

# ========================================
# PRIMARY (Recommended): OpenAI API Key
# ========================================
# Get key from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=

# Optional model override (default in app is gpt-5.1)
# VITE_OPENAI_MODEL=gpt-5.1

# ========================================
# FALLBACK: Gemini AI API Key
# ========================================
# Used if OpenAI key is missing or request fails.
VITE_GEMINI_KEY=

# ========================================
# OPTIONAL: Google Drive Integration
# ========================================
# (Not required for core functionality)
# For future cloud backup feature
# Get from: https://console.cloud.google.com/
#
# VITE_GOOGLE_CLIENT_ID=
# VITE_GOOGLE_DRIVE_FOLDER_EMAIL=your@gmail.com

# ========================================
# NOTES:
# ========================================
# - Never commit .env to Git (it's in .gitignore)
# - Keep your API key secret
# - Restart dev server after changes (Ctrl+C, then npm run dev)
# - File must be named exactly .env (no .txt extension)
# - Must be in project root (same folder as package.json)
#
# Need help? See: GET_GEMINI_KEY.md

# Optional: EmailJS for direct send (without opening mail app)
# VITE_EMAILJS_SERVICE_ID=service_pepg17o
# VITE_EMAILJS_TEMPLATE_ID=template_tyhmgwc
# VITE_EMAILJS_PUBLIC_KEY=bj6U_NGWEtJJAnwSk

# Optional: EmailJS Private Key (for stricter REST auth)
# VITE_EMAILJS_PRIVATE_KEY=
